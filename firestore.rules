rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && getUserData().role == 'Admin';
    }

    function isAgent() {
      return isSignedIn() && getUserData().role == 'Agent';
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profiles ---
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId) || isAdmin();
    }

    // --- Listing Requests (Pipeline) ---
    match /listingRequests/{requestId} {
      allow read: if isAdmin() || (isSignedIn() && (
        existing().get('ownerId', '') == request.auth.uid ||
        (isAgent() && existing().status == 'Agent Bidding')
      ));

      allow create: if isAdmin() || (isSignedIn() && request.auth.uid == incoming().ownerId);

      allow update: if isAdmin() || (
        isSignedIn() && (
          // Case 1: Owner updates specific fields only
          (isOwner(existing().get('ownerId', '')) && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'type', 'price', 'location', 'listingRequirements'])) ||
          // Case 2: Agent updates agentBids via arrayUnion only (cannot overwrite elements)
          (isAgent() && incoming().diff(existing()).affectedKeys().hasOnly(['agentBids']) && incoming().get('agentBids', []).hasAll(existing().get('agentBids', [])))
        )
      );

      allow delete: if isAdmin() || (isSignedIn() && isOwner(existing().get('ownerId', '')));
    }

    // --- Marketplace Properties ---
    match /properties/{propertyId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // --- Transactions Subcollection ---
    match /users/{userId}/transactions/{transactionId} {
      allow read: if isOwner(userId) || isAdmin();
      allow write: if isAdmin(); // Only Cloud Functions/Admin SDK can write
    }

    // --- Chats & Messages ---
    match /chats/{chatId} {
      allow read: if isSignedIn() && request.auth.uid in resource.data.participants;
      allow create: if isSignedIn() && request.auth.uid in incoming().participants;
      allow update: if isSignedIn() && request.auth.uid in existing().participants;

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants;
        allow create: if isSignedIn() && (request.auth.uid == incoming().senderId) && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }

    // --- Disputes ---
    match /disputes/{disputeId} {
      allow read: if isAdmin() || (isSignedIn() && (
        resource.data.buyerId == request.auth.uid || 
        resource.data.agentId == request.auth.uid
      ));
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // --- Announcements ---
    match /announcements/{announcementId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
