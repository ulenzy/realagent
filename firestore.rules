rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Profiles ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['id', 'email', 'name']) 
               && data.id == request.auth.uid
               && data.email is string && data.email.size() <= 256
               && data.name is string && data.name.size() <= 100;
      }

      allow get: if isOwner(userId);
      allow list: if isSignedIn() && resource.data.name != null; // Added to allow name checks query
      allow create: if isSignedIn() && isValidId(userId) && isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming())
                      && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'firstName', 'lastName', 'phoneNumber', 'isAgent', 'role', 'savedProperties', 'tokens', 'bio', 'avatarSeed', 'avatarUrl', 'avatarTier', 'avatarOptions', 'profileScore', 'rating', 'totalReviews', 'preferredLocations', 'gender', 'linkedin', 'onlineHours', 'specializationArea', 'isSubscriber', 'kycStatus', 'kycDocuments', 'isGuest', 'avatarRolls', 'transactions', 'onboardingCompleted']);
      allow delete: if isOwner(userId);
    }

    // --- Property Listings & Promoted Properties ---
    match /properties/{propertyId} {
      function getUserData() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
      }

      function isPromoted(data) {
        return data.get('isPromotedProperty', false) == true;
      }

      function isValidProperty(data, originalOwnerId) {
        return data.keys().hasAll(['id', 'ownerId', 'title', 'price'])
               && data.ownerId == originalOwnerId
               && data.title is string && data.title.size() <= 200
               && data.price is number && data.price >= 0;
      }

      function isValidPromotedProperty(data) {
        return isPromoted(data)
               && data.title is string && data.title.size() <= 200
               && data.price is number && data.price >= 0;
      }

      // Allow reads on promoted properties publicly, and on listing requests only for owners or agents
      allow list, get: if (resource != null && resource.data != null && isPromoted(resource.data)) || (isSignedIn() && (
        resource.data.get('ownerId', '') == request.auth.uid || 
        getUserData().role == 'Agent'
      ));
      
      allow create: if isSignedIn() && (
        (isPromoted(incoming()) && isValidPromotedProperty(incoming())) ||
        (isValidId(propertyId) && isValidProperty(incoming(), request.auth.uid))
      );

      allow update: if isSignedIn() && (
        // Case 1: Promoted property update by owner or agent
        (isPromoted(existing()) && (
          existing().get('ownerId', '') == request.auth.uid ||
          getUserData().role == 'Agent'
        )) ||
        // Case 2: Owner total update for listing request
        (isOwner(existing().get('ownerId', '')) && isValidProperty(incoming(), request.auth.uid) 
         && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'price', 'type', 'estateName', 'location', 'image', 'status', 'description', 'commission', 'acceptsDownPayment', 'documents', 'googlePinLink', 'metrics', 'trustScore', 'assignedAgentId', 'assignedAgentTier', 'listingRequirements', 'agentBids', 'lastUpdated'])) ||
        // Case 3: Agent place bid on listing request
        (getUserData().role == 'Agent' && existing().status == 'Agent Bidding' 
         && incoming().diff(existing()).affectedKeys().hasOnly(['agentBids', 'lastUpdated']) 
         && isValidProperty(incoming(), existing().get('ownerId', '')))
      );

      allow delete: if isSignedIn() && isOwner(existing().get('ownerId', ''));
    }
  }
}
