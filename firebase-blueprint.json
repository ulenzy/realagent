{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "bio": { "type": "string" },
        "avatarSeed": { "type": "string" },
        "avatarUrl": { "type": "string" },
        "avatarTier": { "type": "string" },
        "isAgent": { "type": "boolean" },
        "isSubscriber": { "type": "boolean" },
        "role": { "type": "string" },
        "preferredLocations": { "type": "array" },
        "gender": { "type": "string" },
        "linkedin": { "type": "string" },
        "onlineHours": { "type": "string" },
        "specializationArea": { "type": "string" },
        "kycStatus": { "type": "string" },
        "kycDocuments": { "type": "array" },
        "profileScore": { "type": "number" },
        "rating": { "type": "number" },
        "totalReviews": { "type": "number" },
        "tokens": { "type": "number" },
        "transactions": { "type": "array" },
        "isGuest": { "type": "boolean" },
        "savedProperties": { "type": "array" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "email", "name"]
    },
    "ListingRequest": {
      "title": "ListingRequest",
      "description": "Property listing request in verification pipeline",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerId": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "type": { "type": "string" },
        "location": { "type": "string" },
        "status": { "type": "string" },
        "submittedAt": { "type": "string", "format": "date-time" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "ownerId", "title", "price"]
    },
    "Property": {
      "title": "Property",
      "description": "Real estate listing on the live marketplace",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingRequestId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string" },
        "price": { "type": "number" },
        "sizeSqm": { "type": "number" },
        "bedrooms": { "type": "number" },
        "bathrooms": { "type": "number" },
        "estateName": { "type": "string" },
        "location": { "type": "object" },
        "image": { "type": "string" },
        "gallery": { "type": "array" },
        "agent": { "type": "object" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "title", "price"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A communication channel between flat hunter and agent/seller",
      "type": "object",
      "properties": {
        "participants": { "type": "array" },
        "propertyId": { "type": "string" },
        "propertyName": { "type": "string" },
        "inspectionFeePaid": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastMessage": { "type": "string" },
        "lastTimestamp": { "type": "string" }
      },
      "required": ["participants", "propertyName", "propertyId", "inspectionFeePaid", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "An interactive message inside a chat channel",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "blocked": { "type": "boolean" }
      },
      "required": ["senderId", "receiverId", "text", "timestamp", "blocked"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Authenticated user profiles"
    },
    "listingRequests/{requestId}": {
      "schema": "ListingRequest",
      "description": "Listing requests in pipeline and agent bidding"
    },
    "properties/{propertyId}": {
      "schema": "Property",
      "description": "Marketplace live property listings"
    },
    "chats/{chatId}": {
      "schema": "Chat",
      "description": "Active chat threads"
    },
    "chats/{chatId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Individual messages inside active chat threads"
    }
  }
}
